<div class="max-w-7xl mx-auto py-8 fade-in">
    <div class="flex flex-col md:flex-row justify-between items-center mb-8">
        <h1 class="text-3xl font-bold text-gray-800 border-b-2 border-blue-500 pb-2">Destinations</h1>
        
        <form action="/packages" method="GET" class="mt-4 md:mt-0 flex w-full md:w-auto">
            <input type="text" name="search" value="<%= search %>" placeholder="Search destinations..." class="border border-gray-300 rounded-l-md px-4 py-2 w-full md:w-64 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-r-md hover:bg-blue-700">
                <i class="fa-solid fa-search"></i>
            </button>
        </form>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <% if(packages.length > 0) { %>
            <% packages.forEach(pkg => { %>
                <div class="bg-white rounded-xl shadow border border-gray-100 overflow-hidden hover:shadow-lg transition flex flex-col">
                    <img class="h-48 w-full object-cover" src="<%= pkg.imageUrl %>" alt="<%= pkg.title %>">
                    <div class="p-6 flex-grow flex flex-col">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-xl font-bold text-gray-900"><%= pkg.title %></span>
                            <span class="text-blue-600 font-bold">₹<%= pkg.price %></span>
                        </div>
                        <p class="text-gray-500 text-sm mb-4"><i class="fa-solid fa-location-dot mr-1 text-red-500"></i> <%= pkg.location %></p>
                        <p class="text-gray-600 text-sm mb-4 line-clamp-3 flex-grow"><%= pkg.description %></p>
                        
                        <div class="flex justify-between items-center border-t border-gray-100 pt-4 mt-auto">
                            <span class="text-sm font-medium text-gray-500"><i class="fa-regular fa-clock mr-1"></i> <%= pkg.duration %></span>
                            <a href="/packages/<%= pkg._id %>" class="text-blue-600 hover:text-blue-800 font-medium text-sm border border-blue-600 rounded px-3 py-1 hover:bg-blue-50">Details</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-3 text-center py-12 bg-white rounded shadow text-gray-500">
                <i class="fa-solid fa-magnifying-glass text-4xl mb-3 text-gray-300"></i>
                <p>No packages found matching your criteria.</p>
                <a href="/packages" class="text-blue-500 hover:underline mt-2 inline-block">Clear Search</a>
            </div>
        <% } %>
    </div>

    <!-- Pagination -->
    <% if(pages > 1) { %>
        <div class="flex justify-center mt-10">
            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                <% for(let i=1; i<=pages; i++) { %>
                    <a href="/packages?page=<%= i %><%= search ? '&search='+search : '' %>" 
                       class="relative inline-flex items-center px-4 py-2 border <%= current === i ? 'bg-blue-50 border-blue-500 text-blue-600 z-10' : 'bg-white border-gray-300 text-gray-500 hover:bg-gray-50' %> text-sm font-medium">
                        <%= i %>
                    </a>
                <% } %>
            </nav>
        </div>
    <% } %>
</div>
