<!-- Hero Section -->
<div class="relative bg-gray-900 h-96 mt-[-1.5rem] flex items-center justify-center fade-in">
    <img src="https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" alt="Travel" class="absolute inset-0 w-full h-full object-cover opacity-50">
    <div class="relative z-10 text-center text-white px-4">
        <h1 class="text-5xl font-extrabold mb-4 tracking-tight">Discover Your Next Adventure</h1>
        <p class="text-xl mb-8 text-gray-200">Explore the best travel destinations around the globe.</p>
        <a href="/packages" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-full shadow-lg transition duration-300">
            View All Packages
        </a>
    </div>
</div>

<!-- Featured Packages -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-3xl font-bold text-center text-gray-800 mb-10 border-b-2 border-blue-500 inline-block pb-2">Featured Destinations</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <% if(packages.length > 0) { %>
            <% packages.forEach(pkg => { %>
                <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition duration-300 transform hover:-translate-y-1">
                    <img class="h-48 w-full object-cover" src="<%= pkg.imageUrl %>" alt="<%= pkg.title %>">
                    <div class="p-6">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-xl font-bold text-gray-900"><%= pkg.title %></span>
                            <span class="text-blue-600 font-bold">₹<%= pkg.price %></span>
                        </div>
                        <p class="text-gray-500 text-sm mb-4"><i class="fa-solid fa-location-dot mr-1 text-red-500"></i> <%= pkg.location %></p>
                        <p class="text-gray-600 text-sm mb-4 line-clamp-3"><%= pkg.description %></p>
                        
                        <div class="flex justify-between items-center border-t pt-4">
                            <span class="text-sm font-medium text-gray-500"><i class="fa-regular fa-clock mr-1"></i> <%= pkg.duration %></span>
                            <a href="/packages/<%= pkg._id %>" class="text-blue-600 hover:text-blue-800 font-medium text-sm">Details &rarr;</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-3 text-center text-gray-500">
                <p>No featured packages found. Check back later!</p>
            </div>
        <% } %>
    </div>
</div>
