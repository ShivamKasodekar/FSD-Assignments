<div class="max-w-4xl mx-auto py-12 px-4 fade-in">
    <div class="text-center mb-12">
        <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Contact Us</h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">Have a question or need assistance with your booking? We're here to help.</p>
    </div>

    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden flex flex-col md:flex-row">
        <div class="md:w-1/2 p-8 bg-gray-50 border-r border-gray-100">
            <h3 class="text-2xl font-bold text-gray-900 mb-6">Get in Touch</h3>
            
            <div class="space-y-6">
                <div class="flex items-start">
                    <div class="flex-shrink-0 mt-1 mr-4">
                        <i class="fa-solid fa-location-dot text-blue-600 text-xl"></i>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-900">Headquarters</h4>
                        <p class="text-gray-600">123 Travel Avenue<br>Adventure City, AC 12345<br>United States</p>
                    </div>
                </div>
                
                <div class="flex items-start">
                    <div class="flex-shrink-0 mt-1 mr-4">
                        <i class="fa-solid fa-phone text-blue-600 text-xl"></i>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-900">Phone</h4>
                        <p class="text-gray-600">+1 (555) 123-4567</p>
                        <p class="text-gray-500 text-sm">Mon-Fri, 9am - 6pm EST</p>
                    </div>
                </div>

                <div class="flex items-start">
                    <div class="flex-shrink-0 mt-1 mr-4">
                        <i class="fa-solid fa-envelope text-blue-600 text-xl"></i>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-900">Email</h4>
                        <p class="text-gray-600">support@worldtourr.com</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="md:w-1/2 p-8">
            <form action="#" method="POST" onsubmit="event.preventDefault(); alert('Message sent successfully! (Demo)'); this.reset();">
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Name</label>
                    <input type="text" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:outline-none" required>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Email</label>
                    <input type="email" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:outline-none" required>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Message</label>
                    <textarea rows="4" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:outline-none" required></textarea>
                </div>
                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded shadow transition">Send Message</button>
            </form>
        </div>
    </div>
</div>
