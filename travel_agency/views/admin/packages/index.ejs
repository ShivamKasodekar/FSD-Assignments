<div class="flex flex-col md:flex-row gap-6 fade-in">
    <!-- Admin Sidebar -->
    <div class="w-full md:w-64 flex-shrink-0">
        <div class="bg-gray-900 rounded-lg shadow-lg overflow-hidden text-gray-300">
            <div class="p-4 bg-gray-800 border-b border-gray-700">
                <h2 class="text-xl font-bold text-white"><i class="fa-solid fa-shield-halved text-blue-500 mr-2"></i>Admin Panel</h2>
            </div>
            <nav class="flex flex-col p-2 gap-1">
                <a href="/admin/dashboard" class="px-4 py-3 rounded hover:bg-gray-800 hover:text-white transition"><i class="fa-solid fa-chart-pie w-6"></i> Dashboard</a>
                <a href="/admin/packages" class="px-4 py-3 rounded hover:bg-gray-800 hover:text-white bg-gray-800 text-white transition"><i class="fa-solid fa-map-location-dot w-6"></i> Packages</a>
                <a href="/admin/bookings" class="px-4 py-3 rounded hover:bg-gray-800 hover:text-white transition"><i class="fa-solid fa-suitcase-rolling w-6"></i> Bookings</a>
                <a href="/admin/users" class="px-4 py-3 rounded hover:bg-gray-800 hover:text-white transition"><i class="fa-solid fa-users w-6"></i> Users</a>
            </nav>
        </div>
    </div>

    <!-- Main Content -->
    <div class="flex-grow">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Manage Packages</h1>
            <a href="/admin/packages/new" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded shadow">
                <i class="fa-solid fa-plus mr-1"></i> Add New
            </a>
        </div>
        
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Location</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Price</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <% if(packages && packages.length > 0) { %>
                            <% packages.forEach(pkg => { %>
                                <tr>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            <img class="h-10 w-10 rounded object-cover mr-3" src="<%= pkg.imageUrl %>" alt="">
                                            <div class="text-sm font-medium text-gray-900"><%= pkg.title %> <%= pkg.featured ? '⭐' : '' %></div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= pkg.location %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-bold">₹<%= pkg.price %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                        <div class="flex space-x-3">
                                            <a href="/admin/packages/edit/<%= pkg._id %>" class="text-indigo-600 hover:text-indigo-900"><i class="fa-solid fa-pen-to-square"></i></a>
                                            <form action="/admin/packages/<%= pkg._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this package?');">
                                                <button type="submit" class="text-red-600 hover:text-red-900"><i class="fa-solid fa-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="4" class="px-6 py-4 text-center text-gray-500">No packages found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
