<% if(typeof errors != 'undefined'){ %>
    <% errors.forEach(function(error) { %>
        <div class="alert-msg bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline"><%= error.msg %></span>
        </div>
    <% }); %>
<% } %>

<% if(success_msg && success_msg.length > 0){ %>
    <div class="alert-msg bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4 shadow-sm" role="alert">
        <span class="block sm:inline whitespace-pre-wrap"><i class="fa-solid fa-check-circle mr-1"></i> <%= success_msg %></span>
    </div>
<% } %>

<% if(error_msg && error_msg.length > 0){ %>
    <div class="alert-msg bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4 shadow-sm" role="alert">
        <span class="block sm:inline"><i class="fa-solid fa-triangle-exclamation mr-1"></i> <%= error_msg %></span>
    </div>
<% } %>

<% if(error && error.length > 0){ %>
    <div class="alert-msg bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4 shadow-sm" role="alert">
        <span class="block sm:inline"><%= error %></span>
    </div>
<% } %>
