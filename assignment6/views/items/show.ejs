<div class="max-w-6xl mx-auto py-10 px-4 sm:px-6 lg:px-8 fade-in">
    <div class="mb-6 flex justify-between items-center">
        <a href="/items" class="text-indigo-600 hover:text-indigo-800 font-medium flex items-center transition"><i class="fa-solid fa-arrow-left mr-2"></i> Back to search</a>
        <div class="flex space-x-2 border rounded-lg bg-white p-1">
            <a href="/items/<%= item._id %>/edit" class="px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-md transition"><i class="fa-solid fa-pen mr-1"></i> Edit</a>
            <form action="/items/<%= item._id %>?_method=DELETE" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this listing?');">
                <button type="submit" class="px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-50 rounded-md transition"><i class="fa-solid fa-trash mr-1"></i> Delete</button>
            </form>
        </div>
    </div>

    <div class="bg-white rounded-3xl shadow-lg border border-gray-100 overflow-hidden">
        <div class="md:flex">
            <!-- Image Section -->
            <div class="md:w-1/2 md:flex-shrink-0 bg-gray-100 relative group hidden md:block">
                <img src="<%= item.imageUrl %>" alt="<%= item.title %>" class="w-full h-full object-cover absolute inset-0">
                <div class="absolute inset-0 bg-black bg-opacity-20 hidden group-hover:flex items-center justify-center transition duration-300">
                    <span class="text-white text-xl font-bold glass px-6 py-2 rounded-full cursor-pointer"><i class="fa-solid fa-magnifying-glass-plus mr-2"></i>View</span>
                </div>
            </div>
            
            <!-- Mobile Image -->
            <div class="w-full h-64 md:hidden relative bg-gray-100">
                <img src="<%= item.imageUrl %>" alt="<%= item.title %>" class="w-full h-full object-cover">
            </div>

            <!-- Details Section -->
            <div class="p-8 md:p-12 md:w-1/2 flex flex-col justify-center">
                <div class="uppercase tracking-wider text-sm text-indigo-600 font-bold mb-1"><%= item.category %></div>
                <h1 class="text-4xl font-extrabold text-gray-900 mb-4 tracking-tight"><%= item.title %></h1>
                
                <div class="flex items-center text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-green-500 to-emerald-700 mb-6 pb-6 border-b border-gray-100">
                    ₹<%= item.price.toLocaleString() %>
                </div>

                <div class="grid grid-cols-2 gap-y-6 gap-x-4 mb-8">
                    <div>
                        <p class="text-sm font-medium text-gray-500 mb-1"><i class="fa-solid fa-tag w-5"></i> Condition</p>
                        <p class="text-lg font-semibold text-gray-900"><%= item.condition %></p>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-500 mb-1"><i class="fa-solid fa-location-dot w-5"></i> Location</p>
                        <p class="text-lg font-semibold text-gray-900"><%= item.location %></p>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-500 mb-1"><i class="fa-regular fa-calendar w-5"></i> Listed On</p>
                        <p class="text-lg font-semibold text-gray-900"><%= new Date(item.createdAt).toLocaleDateString() %></p>
                    </div>
                </div>

                <div class="prose max-w-none text-gray-600 mb-8 leading-relaxed">
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Description</h3>
                    <p><%= item.description %></p>
                </div>

                <div class="mt-auto pt-6 border-t border-gray-100">
                    <div class="bg-blue-50 border border-blue-100 rounded-2xl p-6 flex flex-col sm:flex-row items-center justify-between shadow-inner">
                        <div class="text-center sm:text-left mb-4 sm:mb-0">
                            <h3 class="font-bold text-gray-900 text-lg">Interested? Contact Seller</h3>
                            <p class="text-blue-800 font-medium">Reach out to make an offer</p>
                        </div>
                        <a href="tel:<%= item.contactNumber %>" class="flex-shrink-0 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-full shadow-lg transition transform hover:-translate-y-1 block w-full sm:w-auto text-center">
                            <i class="fa-solid fa-phone mr-2"></i> <%= item.contactNumber %>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
