<div class="max-w-3xl mx-auto py-12 px-4 sm:px-6 lg:px-8 fade-in">
    <div class="mb-4">
        <a href="/items/<%= item._id %>" class="text-indigo-600 hover:text-indigo-800 font-medium flex items-center transition"><i class="fa-solid fa-arrow-left mr-2"></i> Cancel Editing</a>
    </div>
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
        <div class="bg-gray-50 py-6 px-8 border-b border-gray-200">
            <h1 class="text-3xl font-extrabold text-gray-900">Edit Listing</h1>
        </div>
        
        <div class="p-8">
            <form action="/items/<%= item._id %>?_method=PUT" method="POST" class="space-y-6">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold text-gray-700 mb-2">Item Title</label>
                        <input type="text" name="title" required value="<%= item.title %>" class="block w-full border border-gray-300 rounded-lg shadow-sm py-3 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-gray-50 focus:bg-white transition">
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Category</label>
                        <select name="category" required class="block w-full border border-gray-300 rounded-lg shadow-sm py-3 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-gray-50 focus:bg-white transition">
                            <option value="Car" <%= item.category === 'Car' ? 'selected' : '' %>>Car</option>
                            <option value="Bike" <%= item.category === 'Bike' ? 'selected' : '' %>>Bike</option>
                            <option value="Electronics" <%= item.category === 'Electronics' ? 'selected' : '' %>>Electronics</option>
                            <option value="Furniture" <%= item.category === 'Furniture' ? 'selected' : '' %>>Furniture</option>
                            <option value="Other" <%= item.category === 'Other' ? 'selected' : '' %>>Other</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Condition</label>
                        <select name="condition" required class="block w-full border border-gray-300 rounded-lg shadow-sm py-3 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-gray-50 focus:bg-white transition">
                            <option value="Like New" <%= item.condition === 'Like New' ? 'selected' : '' %>>Like New</option>
                            <option value="Excellent" <%= item.condition === 'Excellent' ? 'selected' : '' %>>Excellent</option>
                            <option value="Good" <%= item.condition === 'Good' ? 'selected' : '' %>>Good</option>
                            <option value="Fair" <%= item.condition === 'Fair' ? 'selected' : '' %>>Fair</option>
                            <option value="Needs Repair" <%= item.condition === 'Needs Repair' ? 'selected' : '' %>>Needs Repair</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Price (₹)</label>
                        <div class="relative rounded-md shadow-sm">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <span class="text-gray-500 sm:text-sm">₹</span>
                            </div>
                            <input type="number" name="price" required min="0" value="<%= item.price %>" class="block w-full pl-7 border border-gray-300 rounded-lg py-3 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-gray-50 focus:bg-white transition">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Location</label>
                        <input type="text" name="location" required value="<%= item.location %>" class="block w-full border border-gray-300 rounded-lg shadow-sm py-3 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-gray-50 focus:bg-white transition">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Contact Number</label>
                    <input type="text" name="contactNumber" required value="<%= item.contactNumber %>" class="block w-full border border-gray-300 rounded-lg shadow-sm py-3 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-gray-50 focus:bg-white transition">
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Image URL</label>
                    <input type="url" name="imageUrl" value="<%= item.imageUrl %>" class="block w-full border border-gray-300 rounded-lg shadow-sm py-3 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-gray-50 focus:bg-white transition">
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Description</label>
                    <textarea name="description" rows="5" required class="block w-full border border-gray-300 rounded-lg shadow-sm py-3 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-gray-50 focus:bg-white transition"><%= item.description %></textarea>
                </div>

                <div class="pt-4 flex space-x-4">
                    <button type="submit" class="flex-1 flex justify-center py-4 border border-transparent rounded-lg shadow-md text-lg font-bold text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-300">
                        Update Listing
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
